# sobench LLM configuration (OpenAI SDK).
# Copy to .env and fill in real values. .env is git-ignored — never commit it.

# Base URL of the OpenAI-compatible endpoint (e.g. https://api.openai.com/v1
# or a self-hosted / proxy endpoint).
OPENAI_BASE_URL=

# Model name to send in chat-completion requests.
OPENAI_MODEL_NAME=

# API key for the endpoint above.
OPENAI_API_KEY=
